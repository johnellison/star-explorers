# Star Explorers - Environment Variables
# Copy to .env and fill in your keys:  cp .env.example .env

# --- Image Generation ---

# Fal.ai (primary - Flux models for storybook illustrations)
# Get your key at: https://fal.ai/dashboard/keys
FAL_KEY=

# Google AI (Gemini - backup/alternative)
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# --- Flask ---
FLASK_SECRET_KEY=change-me-to-something-random
